# Sao chép thành .env.local và điền giá trị thật (KHÔNG commit .env.local)
# Lấy từ Supabase Dashboard → Project Settings → API

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Chỉ dùng server-side (migration, seed, job hệ thống) — tuyệt đối không lộ ra client
SUPABASE_SERVICE_ROLE_KEY=

# local | dev | prod (Vercel: đặt theo môi trường)
NEXT_PUBLIC_APP_ENV=local
