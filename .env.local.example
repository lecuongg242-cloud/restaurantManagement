# Supabase — sao chép sang .env.local và điền giá trị thật (KHÔNG commit .env.local).
# Lấy tại: Supabase Dashboard → Project Settings → API.

# Public (browser + server)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only — KHÔNG để lộ ra client. Bỏ qua RLS; chỉ dùng trong context server tin cậy.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Server-only (QD-009) — pepper bí mật để suy dẫn mật khẩu Supabase từ PIN nhân viên.
# Tạo chuỗi ngẫu nhiên dài (vd: openssl rand -hex 32). ĐỔI pepper = mọi PIN cũ hết đăng nhập
# được (phải reset PIN). KHÔNG commit giá trị thật.
STAFF_PIN_PEPPER=your-long-random-pepper
